@page "/"

<PageTitle>Home</PageTitle>

<div class="container-fluid w-100">
    <h3>This is to receive base64 encoded data</h3>
    <SimpleDropzone OnBase64FilesReceived=@OnBase64FilesReceived />
    <h3>Dropzone Result:</h3>
    @if (_base64File != null)
    {
        <h4>File Name: @_base64File.Name</h4>
        <h4>File Size: @_base64File.Size</h4>
        <h4>File Type: @_base64File.Type</h4>
        <h4>File Extension: @_base64File.Extension</h4>
        <h4>File Content:</h4>
        <pre class="container-fluid" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
            @_base64File.Content
        </pre>
        @if (!string.IsNullOrWhiteSpace(_base64File.ImgSrc))
        {
            <img class="img-fluid" src="@_base64File.ImgSrc" alt="Uploaded Image" />
        }
    }

    <h3 class="mt-4">This is to receive binary data with all css and text customization</h3>
    <SimpleDropzone
        CssClass="custom"
        DragActiveCssClass="custom-drag-active"
        ContentOutputType=@FileContentOutput.Binary 
        OnBinaryFilesReceived=@OnBinaryFilesReceived >
        <span>As you can see, this is some customized content for binary files. Please drop here to see it working</span>
    </SimpleDropzone>
    <h3>Dropzone Result:</h3>
    @if (_binaryFile != null)
    {
        <h4>File Name: @_binaryFile.Name</h4>
        <h4>File Size: @_binaryFile.Size</h4>
        <h4>File Type: @_binaryFile.Type</h4>
        <h4>File Extension: @_binaryFile.Extension</h4>
        <h4>File Content:</h4>
        <pre class="container-fluid" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
            @(_binaryFile.Content != null 
                ? BitConverter.ToString(_binaryFile.Content).Replace("-", " ") 
                : string.Empty)
        </pre>
        @if (!string.IsNullOrWhiteSpace(_binaryFile.ImgSrc))
        {
            <img class="img-fluid" src="@_binaryFile.ImgSrc" alt="Uploaded Image" />
        }
    }

    <h3 class="mt-4">This is to receive multiple files</h3>
    <SimpleDropzone AllowMultipleFiles=true OnBase64FilesReceived=@OnMultipleFilesReceived />
    <h3>Dropzone Result:</h3>
    @if (_multipleFiles.Any())
    {
        <div class="w-100" style="overflow-x: auto">
            <table class="table">
                <thead>
                    <tr>
                        <th>File Name</th>
                        <th>File Size</th>
                        <th>File Type</th>
                        <th>File Extension</th>
                        <th>File Content (first 100 bytes)</th>
                        <th>Image Preview</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in _multipleFiles)
                    {
                        <tr>
                            <td>@file.Name</td>
                            <td>@file.Size</td>
                            <td>@file.Type</td>
                            <td>@file.Extension</td>
                            <td>
                                <pre style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    @file.Content.Substring(0, 30)
                                </pre>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(file.ImgSrc))
                                {
                                    <span>It is an image, file.ImgSrc is populated</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private Base64FileTransfer? _base64File;
    private BinaryFileTransfer? _binaryFile;
    private List<Base64FileTransfer> _multipleFiles = new();

    private void OnBase64FilesReceived(IEnumerable<Base64FileTransfer> files)
    {
        _base64File = files.FirstOrDefault();
    }

    private void OnBinaryFilesReceived(IEnumerable<BinaryFileTransfer> files)
    {
        _binaryFile = files.FirstOrDefault();
    }

    private void OnMultipleFilesReceived(IEnumerable<Base64FileTransfer> files)
    {
        _multipleFiles.AddRange(files);
    }
}
